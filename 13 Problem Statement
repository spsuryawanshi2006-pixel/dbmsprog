-- =========================================
-- CREATE DATABASE
-- =========================================
CREATE DATABASE StudentMarksDB;

-- =========================================
-- USE DATABASE
-- =========================================
USE StudentMarksDB;

-- =========================================
-- CREATE STUDENTMARKS TABLE
-- =========================================
CREATE TABLE StudentMarks
(
    StudentID INT PRIMARY KEY,
    StudentName VARCHAR(50),
    Subject VARCHAR(50),
    Marks INT
);

