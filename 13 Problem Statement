-- =========================================
-- CREATE TRIGGERS TO VALIDATE MARKS
-- =========================================
DELIMITER //

-- BEFORE INSERT TRIGGER
CREATE TRIGGER Check_Marks_Insert
BEFORE INSERT
ON StudentMarks
FOR EACH ROW
BEGIN

    IF NEW.Marks < 0 OR NEW.Marks > 100 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Marks should be between 0 and 100';
    END IF;

END //

-- BEFORE UPDATE TRIGGER
CREATE TRIGGER Check_Marks_Update
BEFORE UPDATE
ON StudentMarks
FOR EACH ROW
BEGIN

    IF NEW.Marks < 0 OR NEW.Marks > 100 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Marks should be between 0 and 100';
    END IF;

END //

DELIMITER ;

