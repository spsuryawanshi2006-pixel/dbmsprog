-- =========================================
-- CREATE STORED PROCEDURE USING CURSOR
-- =========================================
DELIMITER //

CREATE PROCEDURE DisplayIssuedBooks()
BEGIN

    DECLARE done INT DEFAULT 0;
    DECLARE b_id INT;
    DECLARE s_name VARCHAR(50);
    DECLARE i_date DATE;

    -- CURSOR DECLARATION
    DECLARE book_cursor CURSOR FOR
    SELECT BookID, StudentName, IssueDate
    FROM IssuedBooks;

    -- HANDLER DECLARATION
    DECLARE CONTINUE HANDLER FOR NOT FOUND
    SET done = 1;

    -- OPEN CURSOR
    OPEN book_cursor;

    read_loop: LOOP

        -- FETCH RECORD
        FETCH book_cursor
        INTO b_id, s_name, i_date;

        -- EXIT CONDITION
        IF done = 1 THEN
            LEAVE read_loop;
        END IF;

        -- DISPLAY RECORD
        SELECT b_id AS BookID,
               s_name AS StudentName,
               i_date AS IssueDate;

    END LOOP;

    -- CLOSE CURSOR
    CLOSE book_cursor;

END //

DELIMITER ;

-- =========================================
-- CALL PROCEDURE
-- =========================================
CALL DisplayIssuedBooks();
