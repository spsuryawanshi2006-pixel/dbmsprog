-- =========================================
-- CREATE DATABASE
-- =========================================
CREATE DATABASE LibraryDB;

-- =========================================
-- USE DATABASE
-- =========================================
USE LibraryDB;

-- =========================================
-- CREATE BOOKS TABLE
-- =========================================
CREATE TABLE Books
(
    BookID INT PRIMARY KEY,
    BookTitle VARCHAR(50),
    Author VARCHAR(50),
    AvailableCopies INT
);

-- =========================================
-- CREATE ISSUEDBOOKS TABLE
-- =========================================
CREATE TABLE IssuedBooks
(
    IssueID INT PRIMARY KEY,
    StudentName VARCHAR(50),
    IssueDate DATE,
    BookID INT,

    FOREIGN KEY (BookID)
    REFERENCES Books(BookID)
);

