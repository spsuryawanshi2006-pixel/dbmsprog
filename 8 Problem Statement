-- =========================================
-- DISPLAY TABLES
-- =========================================
SELECT 'DEPARTMENTS TABLE' AS INFO;
SELECT * FROM Departments;

SELECT 'EMPLOYEES TABLE' AS INFO;
SELECT * FROM Employees;

-- =========================================
-- EMPLOYEES WITH SALARY GREATER THAN
-- AVERAGE SALARY
-- =========================================
SELECT EmpName,
       Salary
FROM Employees
WHERE Salary >
(
    SELECT AVG(Salary)
    FROM Employees
);

-- =========================================
-- EMPLOYEES WORKING IN SAME DEPARTMENT
-- AS RAHUL
-- =========================================
SELECT EmpName,
       DeptID
FROM Employees
WHERE DeptID =
(
    SELECT DeptID
    FROM Employees
    WHERE EmpName = 'Rahul'
);

-- =========================================
-- EMPLOYEES WHOSE SALARY IS GREATER THAN
-- THEIR DEPARTMENT AVERAGE SALARY
-- =========================================
SELECT EmpName,
       Salary,
       DeptID
FROM Employees E
WHERE Salary >
(
    SELECT AVG(Salary)
    FROM Employees
    WHERE DeptID = E.DeptID
);

-- =========================================
-- DEPARTMENT NAME OF EMPLOYEE WITH
-- HIGHEST SALARY
-- =========================================
SELECT DeptName
FROM Departments
WHERE DeptID =
(
    SELECT DeptID
    FROM Employees
    WHERE Salary =
    (
        SELECT MAX(Salary)
        FROM Employees
    )
);
