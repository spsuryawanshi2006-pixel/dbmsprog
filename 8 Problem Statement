-- =========================================
-- CREATE DATABASE
-- =========================================
CREATE DATABASE EmployeeDB;

-- =========================================
-- USE DATABASE
-- =========================================
USE EmployeeDB;

-- =========================================
-- CREATE DEPARTMENTS TABLE
-- =========================================
CREATE TABLE Departments
(
    DeptID INT PRIMARY KEY,
    DeptName VARCHAR(50),
    Location VARCHAR(50)
);

-- =========================================
-- CREATE EMPLOYEES TABLE
-- =========================================
CREATE TABLE Employees
(
    EmpID INT PRIMARY KEY,
    EmpName VARCHAR(50),
    Salary INT,
    DeptID INT,

    FOREIGN KEY (DeptID)
    REFERENCES Departments(DeptID)
);

