-- =========================================
-- CREATE FUNCTION TO CALCULATE
-- TOTAL REVENUE
-- =========================================
DELIMITER //

CREATE FUNCTION TotalRevenue()
RETURNS INT
DETERMINISTIC
BEGIN

    DECLARE revenue INT;

    SELECT SUM(Orders.Quantity * Products.Price)
    INTO revenue
    FROM Orders
    INNER JOIN Products
    ON Orders.ProductID = Products.ProductID;

    RETURN revenue;

END //

DELIMITER ;

-- =========================================
-- CALL FUNCTION
-- =========================================
SELECT TotalRevenue() AS Total_Revenue;
