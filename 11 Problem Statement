-- =========================================
-- CREATE DATABASE
-- =========================================
CREATE DATABASE ShoppingDB;

-- =========================================
-- USE DATABASE
-- =========================================
USE ShoppingDB;

-- =========================================
-- CREATE PRODUCTS TABLE
-- =========================================
CREATE TABLE Products
(
    ProductID INT PRIMARY KEY,
    ProductName VARCHAR(50),
    Price INT
);

-- =========================================
-- CREATE ORDERS TABLE
-- =========================================
CREATE TABLE Orders
(
    OrderID INT PRIMARY KEY,
    Quantity INT,
    OrderDate DATE,
    ProductID INT,

    FOREIGN KEY (ProductID)
    REFERENCES Products(ProductID)
);

