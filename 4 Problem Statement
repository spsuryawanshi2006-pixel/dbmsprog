SELECT 'SALES TABLE' AS INFO;

SELECT * FROM Sales;


SELECT Category,
       SUM(Quantity) AS Total_Quantity_Sold
FROM Sales
GROUP BY Category;

SELECT Category,
       AVG(Price) AS Average_Price
FROM Sales
GROUP BY Category;

SELECT Category,
       MAX(Price) AS Maximum_Price,
       MIN(Price) AS Minimum_Price
FROM Sales
GROUP BY Category;


SELECT Category,
       SUM(Quantity * Price) AS Total_Sales_Amount
FROM Sales
GROUP BY Category;


SELECT Category,
       COUNT(ProductName) AS Number_Of_Products
FROM Sales
GROUP BY Category;


SELECT Category,
       SUM(Quantity * Price) AS Total_Sales
FROM Sales
GROUP BY Category
HAVING SUM(Quantity * Price) > 5000;


SELECT Category,
       AVG(Price) AS Average_Price
FROM Sales
GROUP BY Category
HAVING AVG(Price) > 1000;


SELECT Category,
       SUM(Quantity * Price) AS Highest_Total_Sales
FROM Sales
GROUP BY Category
ORDER BY Highest_Total_Sales DESC
LIMIT 1;
