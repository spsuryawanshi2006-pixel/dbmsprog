CREATE DATABASE BankDB;

USE BankDB;

CREATE TABLE Account (
    AccountID INT PRIMARY KEY,
    CustomerName VARCHAR(50),
    Balance DECIMAL(10,2),
    AccountType VARCHAR(20)
);

INSERT INTO Account VALUES
