-- =========================================
-- CREATE DATABASE
-- =========================================
CREATE DATABASE HospitalDB;

-- =========================================
-- USE DATABASE
-- =========================================
USE HospitalDB;

-- =========================================
-- CREATE BILLING TABLE
-- =========================================
CREATE TABLE Billing
(
    BillID INT PRIMARY KEY,
    PatientName VARCHAR(50),
    Department VARCHAR(50),
    Amount INT,
    DaysAdmitted INT
);

