-- =========================================
-- DISPLAY BILLING TABLE
-- =========================================
SELECT 'BILLING TABLE' AS INFO;

SELECT * FROM Billing;

-- =========================================
-- TOTAL BILLING DEPARTMENT WISE
-- =========================================
SELECT Department,
       SUM(Amount) AS Total_Billing
FROM Billing
GROUP BY Department;

-- =========================================
-- AVERAGE BILLING DEPARTMENT WISE
-- =========================================
SELECT Department,
       AVG(Amount) AS Average_Billing
FROM Billing
GROUP BY Department;

-- =========================================
-- MAXIMUM AND MINIMUM BILL DEPARTMENT WISE
-- =========================================
SELECT Department,
       MAX(Amount) AS Maximum_Bill,
       MIN(Amount) AS Minimum_Bill
FROM Billing
GROUP BY Department;

-- =========================================
-- TOTAL PATIENTS DEPARTMENT WISE
-- =========================================
SELECT Department,
       COUNT(*) AS Total_Patients
FROM Billing
GROUP BY Department;

-- =========================================
-- TOTAL DAYS ADMITTED DEPARTMENT WISE
-- =========================================
SELECT Department,
       SUM(DaysAdmitted) AS Total_Days
FROM Billing
GROUP BY Department;

-- =========================================
-- DEPARTMENTS WITH TOTAL BILLING > 20000
-- =========================================
SELECT Department,
       SUM(Amount) AS Total_Billing
FROM Billing
GROUP BY Department
HAVING SUM(Amount) > 20000;

-- =========================================
-- DEPARTMENTS WITH AVERAGE STAY > 3 DAYS
-- =========================================
SELECT Department,
       AVG(DaysAdmitted) AS Average_Stay
FROM Billing
GROUP BY Department
HAVING AVG(DaysAdmitted) > 3;

-- =========================================
-- DEPARTMENT WITH HIGHEST BILLING
-- =========================================
SELECT Department,
       SUM(Amount) AS Highest_Billing
FROM Billing
GROUP BY Department
ORDER BY Highest_Billing DESC
LIMIT 1;
